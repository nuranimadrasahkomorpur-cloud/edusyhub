generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  email       String?  @unique
  password    String
  name        String?
  phone       String?  @unique // Added for personal contact info and unique login
  role        Role     @default(STUDENT)

  
  // Many-to-Many with Institute (Admins can manage multiple)
  institutes    Institute[] @relation(fields: [instituteIds], references: [id])
  instituteIds  String[]    @db.ObjectId
  
  // Single active/default institute for dashboard
  defaultInstituteId String? @db.ObjectId
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Dynamic fields storage
  metadata    Json?

  teacherProfiles TeacherProfile[]
  assignments     Assignment[] @relation("TeacherAssignments")
  submissions     Submission[] @relation("StudentSubmissions")
  
  // Attendance & FRS
  faceDescriptor  Json?
  attendances     Attendance[] @relation("StudentAttendance")
}

model Institute {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  type        String?  // e.g., "Madrasa", "Kindergarten"
  address     String?
  phone       String?
  email       String?
  website     String?
  logo        String?
  coverImage  String?  // Added for dashboard cover
  
  // Form Configuration
  studentFormConfig Json?

  // Assignment release time (global for all classes, HH:mm format e.g. "06:00")
  assignmentReleaseTime String?

  // Many-to-Many with User
  admins      User[]   @relation(fields: [adminIds], references: [id])
  adminIds    String[] @db.ObjectId
  
  teacherProfiles TeacherProfile[]

  // Relations
  classes     Class[]
  books       Book[]
  accountCategories AccountCategory[]
  transactions      Transaction[]
  
  // Notification Settings
  notificationSettings Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments Assignment[]
  attendances Attendance[]
  subscriptions Subscription[]
}

model Class {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  order       Int      @default(0)
  
  // Class start time used as assignment deadline (HH:mm format e.g. "09:00")
  startTime   String?
  endTime     String?
  tiffinStart String?
  tiffinEnd   String?
  
  schedule    Json?
  fees        Int?      @default(0)
  lateThreshold Int?    @default(15) // Minutes

  institute   Institute @relation(fields: [instituteId], references: [id])
  instituteId String    @db.ObjectId
  
  groups      Group[]
  books       Book[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coverImage  String?  // Added for diary cover image
  assignments Assignment[]
  attendances Attendance[]
}

model Group {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  order       Int      @default(0)
  
  class       Class    @relation(fields: [classId], references: [id])
  classId     String   @db.ObjectId
  
  books       Book[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments Assignment[]
  attendances Attendance[]
}


enum Role {
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  TEACHER
  GUARDIAN
  STUDENT
  DEMO
}


model SiteSettings {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  appName        String   @default("Edusy")
  logo           String?
  coverImage     String?
  introduction   String?
  supportEmail   String?
  supportPhone   String?
  
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model TeacherProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  
  instituteId String   @db.ObjectId
  institute   Institute @relation(fields: [instituteId], references: [id])
  
  designation String?
  department  String?
  joinDate    DateTime @default(now())
  
  // Permissions: { canCollectFees: boolean, canManageResult: boolean, canTakeAttendance: boolean, ... }
  permissions Json?    
  
  // Class Restrictions: List of Class IDs this teacher acts upon
  assignedClassIds String[] @db.ObjectId
  
  isAdmin     Boolean  @default(false)
  status      String   @default("PENDING") // PENDING, ACTIVE, REJECTED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, instituteId])
}

model Notification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  type        String   // "TEACHER_LEFT", "TEACHER_REMOVED", etc.
  title       String
  message     String
  status      String   @default("SENT") // SENT, DELIVERED, READ, CLICKED
  read        Boolean  @default(false)
  metadata    Json?    // Store additional info like teacher name, institute name, instituteId
  batchId     String?  // For group notifications analytics
  seenAt      DateTime?
  clickedAt   DateTime?
  createdAt   DateTime @default(now())
}

model Book {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  nameBangla  String?  // Multilingual name
  nameEnglish String?  // Multilingual name
  nameArabic  String?  // Multilingual name
  description String?  // Book description
  coverImage  String?  // Added for book cover
  author      String?  // Added for book subtitle/author
  rating      Float?   @default(4.0) // Added for book rating
  pdfUrl      String?  // Link to uploaded PDF
  readLink    String?  // Link to external reading site
  
  category    String?  // Added for book categorization (e.g., "Fiction", "Science")
  
  class       Class?   @relation(fields: [classId], references: [id])
  classId     String?  @db.ObjectId
  
  group       Group?   @relation(fields: [groupId], references: [id])
  groupId     String?  @db.ObjectId
  
  institute   Institute? @relation(fields: [instituteId], references: [id])
  instituteId String?    @db.ObjectId
  
  // Grading Settings
  totalMarks   Int?      @default(100)
  gradingRules Json?     // Array of GradingRule objects
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments Assignment[]
}

model Assignment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String?  // Optional - auto-generated from subject/book name if not set
  description String?
  type        AssignmentType @default(HOMEWORK)
  status      AssignmentStatus @default(PUBLISHED)
  deadline    DateTime?
  
  // Relations
  institute   Institute @relation(fields: [instituteId], references: [id])
  instituteId String    @db.ObjectId
  
  teacher     User      @relation("TeacherAssignments", fields: [teacherId], references: [id])
  teacherId   String    @db.ObjectId
  
  class       Class?    @relation(fields: [classId], references: [id])
  classId     String?   @db.ObjectId
  
  group       Group?    @relation(fields: [groupId], references: [id])
  groupId     String?   @db.ObjectId
  
  book        Book?     @relation(fields: [bookId], references: [id])
  bookId      String?   @db.ObjectId
  
  submissions Submission[]
  
  // Resource references (PDFs, Notes, Suggestions)
  resources   Json?     // Array of { name: string, url: string, type: string }
  
  createdAt     DateTime @default(now())
  scheduledDate DateTime @default(now())
  releaseAt     DateTime?
  studentIds    String[]   @db.ObjectId
  
  updatedAt     DateTime @updatedAt
}

model Submission {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  assignment    Assignment @relation(fields: [assignmentId], references: [id])
  assignmentId  String     @db.ObjectId
  
  student       User       @relation("StudentSubmissions", fields: [studentId], references: [id])
  studentId     String     @db.ObjectId
  
  content       String?    // Text answer
  attachments   Json?      // Array of { name, url, type }
  
  // Track progress for individual tasks within structured assignments
  // Format: { [taskId]: { status: 'DONE' | 'PENDING', submittedBy: 'TEACHER'|'STUDENT'|'GUARDIAN', submittedAt: Date, feedback: string } }
  taskProgress  Json?      

  status        SubmissionStatus @default(SUBMITTED)
  grade         String?
  feedback      String?
  
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([assignmentId, studentId])
}

enum AssignmentType {
  HOMEWORK
  CLASSWORK
  REVISION
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  RELEASED
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  APPROVED
  RETRY
  REJECTED
}

model Attendance {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  student     User     @relation("StudentAttendance", fields: [studentId], references: [id])
  studentId   String   @db.ObjectId
  
  institute   Institute @relation(fields: [instituteId], references: [id])
  instituteId String    @db.ObjectId
  
  class       Class?    @relation(fields: [classId], references: [id])
  classId     String?   @db.ObjectId

  group       Group?    @relation(fields: [groupId], references: [id])
  groupId     String?   @db.ObjectId
  
  date        DateTime @default(now())
  dateString  String   // YYYY-MM-DD for uniqueness
  status      AttendanceStatus @default(PRESENT)
  method      AttendanceMethod @default(MANUAL) // MANUAL, FRS, QR
  
  remarks     String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, dateString])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  LEAVE_PENDING
}

enum AttendanceMethod {
  MANUAL
  FRS
  QR
}

model AccountCategory {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  type            TransactionType
  recipient       String?
  frequency       String?
  amount          Float?
  isFixed         Boolean  @default(true)
  instituteId     String   @db.ObjectId
  institute       Institute @relation(fields: [instituteId], references: [id])
  config          Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  amount      Float
  type        TransactionType
  category    String
  categoryId  String?  @db.ObjectId
  studentId   String?  @db.ObjectId
  studentName String?
  classId     String?  @db.ObjectId
  className   String?
  note        String?
  status      TransactionStatus @default(COMPLETED)
  date        DateTime @default(now())
  
  instituteId String   @db.ObjectId
  institute   Institute @relation(fields: [instituteId], references: [id])
  
  receiptNo   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  COMPLETED
  PENDING
  CANCELLED
}

model Package {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  price       Float
  duration    Int      // in days
  features    String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  instituteId String   @db.ObjectId
  institute   Institute @relation(fields: [instituteId], references: [id])
  packageId   String   @db.ObjectId
  package     Package  @relation(fields: [packageId], references: [id])
  status      String   @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  startDate   DateTime @default(now())
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Announcement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  content     String
  type        String   @default("GLOBAL") // GLOBAL, INSTITUTE
  instituteId String?  @db.ObjectId
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
